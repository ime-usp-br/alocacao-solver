REDIS_URL=redis://redis:6379

# Porta exposta no host pela API (compose de producao).
# Padrao 8015 (homologacao). Sobrescreva no .env do servidor de producao.
API_HOST_PORT=8015

# ---------------------------------------------------------------------------
# Tuning do CP-SAT (worker) — controle de memória para evitar OOM kill.
# ---------------------------------------------------------------------------
# Nº de workers paralelos da busca. Cada worker clona o modelo + estado,
# multiplicando o consumo de RAM. Em servidores com muitos cores o padrão
# do OR-Tools (= nº de cores) estoura a memória e o kernel mata o work-horse.
CP_SAT_NUM_SEARCH_WORKERS=4

# Teto de memória (MB) do CP-SAT: ao atingir, ele encerra a busca e retorna
# FEASIBLE em vez de crescer até ser morto. Deve ser < WORKER_MEM_LIMIT.
CP_SAT_MAX_MEMORY_MB=3500

# Limite de memória do container worker no compose de produção.
WORKER_MEM_LIMIT=4g
WORKER_MEMSWAP_LIMIT=4g
